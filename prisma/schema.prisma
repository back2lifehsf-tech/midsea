// Midsea — modelo de dominio v1 (ver PRD.md secciones 1.4 y 3)
// Source of truth para parent/student/curriculum/COIN.
//
// Rebrand Nexos → COIN: el código Prisma usa nombres nuevos (CoinEntry,
// CoinReason, rewardCoin) pero las tablas/columnas/enum types en DB
// se mapean a los nombres viejos (NexosEntry, NexosReason, rewardNexos)
// via @@map / @map para evitar una migration breaking en prod. La
// rename física de la DB queda para cuando estabilicemos esquema
// post-PMF.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Locale {
  es
  en
}

enum Role {
  PARENT
  STUDENT
  ADMIN
}

enum Subject {
  MATH
  LANGUAGE_ARTS
  SCIENCE
  SOCIAL_STUDIES
  FOREIGN_LANGUAGE
  ELECTIVE
}

enum LessonStatus {
  LOCKED
  AVAILABLE
  IN_PROGRESS
  MASTERED
}

// Epic 03 + ADR-001 §10: estado de suscripción por estudiante.
// PENDING_PAYMENT cubre el caso "padre llenó form pero no pagó / el cobro
// falló". Hasta que llegue ACTIVE el estudiante NO puede usar Angela.
enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  PENDING_PAYMENT
  CANCELED
  PAUSED
}

enum PlanTier {
  CORE
  PRO
  FAMILY
}

enum BillingCycle {
  MONTHLY
  ANNUAL
}

// Epic 04 + ADR-005 §7: catálogo a la carta. SubjectArea reemplaza
// (a futuro) al enum Subject — coexisten en v1 mientras migramos las
// lecciones legacy. SubjectArea cubre las 6 materias del pilot HS +
// catch-all electivas para v1.1.
enum SubjectArea {
  MATH
  LANGUAGE
  ENGLISH_ESL
  HISTORY
  SCIENCE
  MUSIC
  ELECTIVE_OTHER
}

// GradeBand abstrae "qué nivel del Secundario argentino cubre el
// curso". Mapeo per ADR-003: Ciclo Básico = 9°-10° (1°-2° Sec AR);
// Ciclo Orientado = 11°-12° (3°-5° Sec AR). TRANSVERSAL para cursos
// que no se atan a 1 año (Inglés ESL, Historia, Música).
enum GradeBand {
  CICLO_BASICO
  CICLO_ORIENTADO
  TRANSVERSAL
}

enum CoinReason {
  LESSON_MASTERY
  BADGE
  STREAK
  PARENT_GRANT
  STORE_PURCHASE
  ADJUSTMENT

  @@map("NexosReason")
}

model Family {
  id          String   @id @default(cuid())
  name        String
  locale      Locale   @default(es)
  createdAt   DateTime @default(now())
  parents     Parent[]
  students    Student[]
}

model Parent {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  // bcrypt hash. Nullable: parents que firmaron con Google OAuth no tienen
  // password local. Epic 01 §3a: Credentials Provider para email+password.
  passwordHash String?
  family       Family   @relation(fields: [familyId], references: [id], onDelete: Cascade)
  familyId     String
  createdAt    DateTime @default(now())
  // Epic 03 + ADR-001 §2: un Customer de Stripe por Parent. Nullable: se
  // crea on-demand al primer cobro (no en signup) para evitar Customers
  // huérfanos que no van a comprar.
  stripeCustomerId String? @unique

  // Epic 04 + ADR-005: el padre activa cursos por hijo. Back-relation.
  courseActivations StudentCourseEnrollment[]

  @@index([familyId])
}

model Student {
  id              String          @id @default(cuid())
  displayName     String
  birthDate       DateTime
  gradeLevel      Int             // 0 = PreK, 1..12
  preferredLocale Locale          @default(es)
  // bcrypt hash de PIN de 4 dígitos. Epic 01 §3b: niños K-2 no tienen email,
  // entran eligiendo avatar + PIN. Nullable mientras el padre no asigna PIN.
  pinHash         String?
  // Identificador del avatar (referencia a src/lib/auth/avatars.ts).
  avatarKey       String?
  // Notas opcionales que el padre le pasa a Angela ("hace 6 meses ADHD
  // dx, prefiere ejemplos cortos"). Epic 03 — Step A del NewStudentDialog.
  angelaNotes     String?         @db.Text
  family          Family          @relation(fields: [familyId], references: [id], onDelete: Cascade)
  familyId        String
  createdAt       DateTime        @default(now())

  // Epic 03 + ADR-001 §10: state de suscripción.
  //   - subscriptionStatus arranca en PENDING_PAYMENT al crear el Student
  //     (antes de cobrar). El webhook payment_intent.succeeded lo lleva
  //     a ACTIVE.
  //   - monthlyAmountCents es el "precio efectivo del mes" (anual / 12
  //     o monthly). Permite que Parent Copilot sume sin recalcular cycles.
  subscriptionStatus    SubscriptionStatus @default(PENDING_PAYMENT)
  planTier              PlanTier?
  billingCycle          BillingCycle?
  stripeSubscriptionId  String?            @unique
  currentPeriodEnd      DateTime?
  monthlyAmountCents    Int?

  progress        LessonProgress[]
  ledger          CoinEntry[]
  earnedBadges    EarnedBadge[]
  tutorSessions   TutorSession[]
  tutorUsage      TutorUsageDaily[]
  enrollments     StudentCourseEnrollment[]

  @@index([familyId])
  @@index([subscriptionStatus])
}

model Lesson {
  id          String       @id @default(cuid())
  slug        String       @unique
  subject     Subject
  gradeLevel  Int
  // Contenido bilingue: PRD seccion 3.3 — el espanol es la fuente, ingles es adaptacion cultural.
  titleEs     String
  titleEn     String
  summaryEs   String
  summaryEn   String
  estMinutes  Int          @default(15)
  rewardCoin  Int          @default(100) @map("rewardNexos")
  orderIndex  Int          @default(0)
  createdAt   DateTime     @default(now())

  // Epic 04 + ADR-005: cada Lesson pertenece a un Course del catálogo.
  // Nullable en v1 para permitir lecciones legacy (Epic 01 seed) sin
  // ruptura; el pipeline de generación (Tarea 2-4) siempre lo seta.
  course      Course?      @relation(fields: [courseId], references: [id])
  courseId    String?
  // mes del calendario académico del outline (1..12) — sirve para
  // ordenar lecciones secuencialmente dentro de un curso aunque el
  // estudiante navegue libre. nullable hasta ingestar contenido real.
  monthIndex  Int?
  // Body en markdown + activities array + reflexión cristiana opcional
  // (ADR-007). Schema completo del ingest se define en Tarea 2 vía Zod.
  // bodyMd = español (contentMarkdownEs); bodyMdEn = inglés
  // (contentMarkdownEn). El pipeline genera ambos; el lesson player
  // elige según locale (fallback a bodyMd si bodyMdEn falta).
  bodyMd      String?      @db.Text
  bodyMdEn    String?      @db.Text
  activities  Json?
  reflectionEs String?     @db.Text
  reflectionEn String?     @db.Text

  progress      LessonProgress[]
  competencies  LessonCompetency[]
  quizQuestions QuizQuestion[]

  @@index([subject, gradeLevel])
  @@index([courseId, monthIndex, orderIndex])
}

// Epic 04 + ADR-005 §7: catálogo HS Pilot Mínimo de 8 cursos.
// Cada Course es la unidad atómica que el padre activa por hijo.
// `slug` es la clave canónica que el pipeline usa para vincular las
// lecciones generadas con el curso correcto.
model Course {
  id            String       @id @default(cuid())
  slug          String       @unique
  titleEs       String
  titleEn       String
  descriptionEs String       @db.Text
  descriptionEn String       @db.Text
  subject       SubjectArea
  gradeBand     GradeBand
  orderIndex    Int          @default(0)
  published     Boolean      @default(false)
  thumbnailUrl  String?
  createdAt     DateTime     @default(now())

  lessons       Lesson[]
  competencies  Competency[]
  enrollments   StudentCourseEnrollment[]

  @@index([subject, gradeBand, published])
}

// Epic 04 + ADR-005 §7: competencias dentro de un Course. `code` es
// una clave semántica tipo "ARG-MATH-CB-01". `prerequisites`/`unblocks`
// es self-relation many-to-many (una competencia puede requerir otras
// + desbloquear otras). El MasteryMap del estudiante es derivable de
// LessonProgress agregado por Competency.
model Competency {
  id            String   @id @default(cuid())
  course        Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  courseId      String
  code          String
  descriptionEs String   @db.Text
  descriptionEn String   @db.Text
  orderIndex    Int      @default(0)

  prerequisites Competency[] @relation("CompetencyPrereqs")
  unblocks      Competency[] @relation("CompetencyPrereqs")

  lessons       LessonCompetency[]

  @@unique([courseId, code])
}

// Epic 04 + ADR-005 §7: join Lesson ↔ Competency. `weight` permite
// que una lección "cuente" 100% para una competencia pero solo 30%
// para otra (e.g. lección de fracciones aporta a "operar racionales"
// + parcialmente a "resolver problemas de proporcionalidad").
model LessonCompetency {
  lesson       Lesson      @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  lessonId     String
  competency   Competency  @relation(fields: [competencyId], references: [id], onDelete: Cascade)
  competencyId String
  weight       Int         @default(100)

  @@id([lessonId, competencyId])
}

// Epic 04 + ADR-005: enrollment del estudiante en un curso del catálogo.
// La fuente de verdad de "qué cursos toma cada hijo". onDelete:Restrict
// sobre Course evita borrar un curso con enrollments activos (proteger
// progreso del estudiante).
model StudentCourseEnrollment {
  id                  String   @id @default(cuid())
  student             Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  studentId           String
  course              Course   @relation(fields: [courseId], references: [id], onDelete: Restrict)
  courseId            String
  activatedAt         DateTime @default(now())
  activatedBy         Parent   @relation(fields: [activatedByParentId], references: [id])
  activatedByParentId String
  deactivatedAt       DateTime?
  active              Boolean  @default(true)

  @@unique([studentId, courseId])
  @@index([studentId, active])
}

// Epic 04 §4: preguntas del quiz final de una lección. `correctAnswer`
// se mantiene server-side; el cliente envía respuestas, el server las
// puntúa. `type` controla el render: 'multiple_choice', 'fill_in_blank',
// 'short_answer', 'step_by_step'.
model QuizQuestion {
  id            String   @id @default(cuid())
  lesson        Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  lessonId      String
  orderIndex    Int      @default(0)
  type          String
  promptEs      String   @db.Text
  promptEn      String   @db.Text
  options       Json?
  correctAnswer Json
  explanationEs String?  @db.Text
  explanationEn String?  @db.Text

  @@index([lessonId, orderIndex])
}

model LessonProgress {
  id          String       @id @default(cuid())
  student     Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  studentId   String
  lesson      Lesson       @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  lessonId    String
  status      LessonStatus @default(AVAILABLE)
  masteryPct  Int          @default(0) // 0..100
  attempts    Int          @default(0)
  lastAttempt DateTime?
  updatedAt   DateTime     @updatedAt

  @@unique([studentId, lessonId])
  @@index([studentId, status])
}

model CoinEntry {
  id        String      @id @default(cuid())
  student   Student     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  studentId String
  amount    Int         // positivo = gana, negativo = gasta
  reason    CoinReason
  // Metadata libre: lessonId, badgeId, storeItemId, etc.
  refId     String?
  note      String?
  createdAt DateTime    @default(now())

  @@index([studentId, createdAt])
  @@map("NexosEntry")
}

model Badge {
  id          String        @id @default(cuid())
  code        String        @unique
  nameEs      String
  nameEn      String
  descriptionEs String
  descriptionEn String
  iconKey     String        // referencia a public/assets/badges/<key>.svg
  rewardCoin  Int           @default(0) @map("rewardNexos")

  earned      EarnedBadge[]
}

model EarnedBadge {
  id        String   @id @default(cuid())
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  studentId String
  badge     Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  badgeId   String
  earnedAt  DateTime @default(now())

  @@unique([studentId, badgeId])
  @@index([studentId])
}

model TutorSession {
  id         String       @id @default(cuid())
  student    Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  studentId  String
  locale     Locale
  topic      String?
  createdAt  DateTime     @default(now())
  endedAt    DateTime?

  messages   TutorMessage[]

  @@index([studentId, createdAt])
}

model TutorMessage {
  id        String       @id @default(cuid())
  session   TutorSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sessionId String
  role      String       // "user" | "assistant" | "system"
  content   String       @db.Text
  // Epic 02 §3: tokens consumidos + modelo por turno. JSON libre para
  // permitir extender con latency, cost estimate, etc. sin nueva migration.
  metadata  Json?
  createdAt DateTime     @default(now())

  @@index([sessionId, createdAt])
}

// Epic 02 §1.7 + §3.9: rate limit por estudiante + telemetría de costos.
// Una fila por (estudiante, día UTC). El bump del contador es upsert
// atómico; ver src/lib/tutor/rate-limit.ts.
model TutorUsageDaily {
  id         String   @id @default(cuid())
  student    Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  studentId  String
  date       DateTime @db.Date
  msgCount   Int      @default(0)
  tokensUsed Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([studentId, date])
  @@index([studentId])
}

// Epic 03 + ADR-001 §9: idempotencia de webhooks de Stripe.
// `id` = Stripe event id (`evt_...`). Si recibimos el mismo evento dos
// veces (retry de Stripe, replay), upsert no-op. Sin esto, un
// payment_intent.succeeded duplicado podría disparar acciones dobles
// (segundo cargo, doble email, etc.).
model StripeWebhookEvent {
  id          String   @id
  type        String
  payload     Json
  processedAt DateTime @default(now())

  @@index([type, processedAt])
}

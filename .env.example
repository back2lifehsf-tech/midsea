# Copia este archivo a .env.local y rellena los valores reales.
# Nunca commitees .env.local — solo servidor.

# Base de datos
DATABASE_URL="postgresql://user:password@localhost:5432/midsea?schema=public"

# OpenAI (servidor)
OPENAI_API_KEY="sk-..."
OPENAI_MODEL="gpt-4o-mini"

# NextAuth — Google OAuth + JWT sessions
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="cambiame-en-produccion"

# Google OAuth
# Obten clientId/secret en https://console.cloud.google.com/apis/credentials
# Redirect URI autorizado: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# i18n
DEFAULT_LOCALE="es"

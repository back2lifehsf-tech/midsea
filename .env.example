# Copia este archivo a .env.local y rellena los valores reales.
# Nunca commitees .env.local — solo servidor.

# Base de datos
DATABASE_URL="postgresql://user:password@localhost:5432/midsea?schema=public"

# OpenAI (servidor)
OPENAI_API_KEY="sk-..."
OPENAI_MODEL="gpt-4o-mini"

# NextAuth — Google OAuth + JWT sessions
# NEXTAUTH_URL: la URL publica del deploy. En Vercel, usa la URL del proyecto
#   (e.g. https://midsea.vercel.app). Localmente: http://localhost:3000.
# NEXTAUTH_SECRET: cadena aleatoria larga. Genera una con:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
#   o:  openssl rand -base64 32
# En Vercel: agregar como Environment Variable en Project Settings (Production
# + Preview). Sin esto el handler de NextAuth tira en runtime.
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="cambiame-en-produccion-genera-con-openssl-rand-base64-32"

# Google OAuth
# Obten clientId/secret en https://console.cloud.google.com/apis/credentials
# Redirect URI autorizado: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# i18n
DEFAULT_LOCALE="es"

# === Stripe (Billing) ===
# Test mode para dev, live solo en producción.
# API keys: https://dashboard.stripe.com/test/apikeys
# Productos y Prices: crear en Stripe Dashboard antes de poblar IDs.
# Ver: docs/decisions/ADR-001-billing-stack.md
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Price IDs (rotables sin redeploy de código)
STRIPE_PRICE_CORE_MONTHLY="price_..."
STRIPE_PRICE_CORE_ANNUAL="price_..."
STRIPE_PRICE_PRO_MONTHLY="price_..."
STRIPE_PRICE_PRO_ANNUAL="price_..."
STRIPE_PRICE_FAMILY_MONTHLY="price_..."

# % de descuento aplicado al ciclo anual (informativo en UI; NO recalcula facturación)
ANNUAL_DISCOUNT_PCT="30"
